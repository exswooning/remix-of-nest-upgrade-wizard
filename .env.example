# Supabase — project you own (created at supabase.com, not via Lovable).
# Get these from Project Settings → API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# The service-role key is NEVER added here — it goes only into Edge Function
# env vars (Supabase dashboard → Edge Functions → Secrets). Adding it to
# anything with the VITE_ prefix would leak it into the browser bundle.

# Optional: prefix URL for the Nepal IRD PAN/VAT lookup proxy. The browser
# can't talk to ird.gov.np directly (CORS), so this needs to point at a
# server-side proxy you control. The proxy receives the target URL as an
# URL-encoded suffix:
#   VITE_PAN_PROXY_URL=https://your-worker.workers.dev/?url=
# A reference Cloudflare Worker lives in scripts/pan-vat-proxy.worker.js.
# If unset, the app falls through to corsproxy.io (rate-limited) and the
# manual-paste fallback in the UI.
VITE_PAN_PROXY_URL=

# Best path for fully-automated PAN/VAT lookup: a Render.com-deployed
# Puppeteer microservice that runs a real headless Chromium against
# ird.gov.np (handles their reCAPTCHA invisibly). Free tier of Render is
# sufficient. Full deploy guide: scripts/pan-puppeteer-render/README.md.
#
#   VITE_PAN_LOOKUP_URL=https://pan-puppeteer-xxxx.onrender.com
#   VITE_PAN_LOOKUP_KEY=<random string matching the service's ACCESS_KEY>
#
# Without these, the app falls back to the clipboard bridge — still
# works, just needs the user to ⌘A → ⌘C on the IRD page first.
VITE_PAN_LOOKUP_URL=
VITE_PAN_LOOKUP_KEY=

# Sejda PDF backend — Spring Boot service in `sejda-backend/`. Setting
# this exposes a "Sejda backend" switch on the DCAP toolbar; when on,
# merge / split / rotate / extract route through the server-side Sejda
# library (the same one that powers sejda.com) instead of the
# browser-side pdf-lib path. No quota, no upload limits beyond the
# server's own.
#
# Local:   VITE_SEJDA_BACKEND_URL=http://localhost:8089
# Render:  VITE_SEJDA_BACKEND_URL=https://your-sejda-backend.onrender.com
# Leave blank to hide the toggle entirely (default).
VITE_SEJDA_BACKEND_URL=

# Stirling PDF — full sejda-style web editor (merge / split / rotate /
# OCR / watermark / sign / inline-edit text / forms / redact / convert
# / compress, etc.). Self-hosted Docker container in `stirling-pdf/`.
# When this is set, the DCAP tab embeds the Stirling UI as an iframe
# instead of the browser-side pdf-lib tile grid.
#
# Setup:
#   cd stirling-pdf && docker compose up -d
#   open http://localhost:8084   (Stirling boots in ~30-60s the first time)
#
# Local:      VITE_STIRLING_URL=http://localhost:8084
# Deployed:   VITE_STIRLING_URL=https://stirling.your-domain.com
VITE_STIRLING_URL=

# PyMuPDF backend — Python sidecar in `pymupdf-backend/` that powers
# the DCAP **inline editor**'s Save with sejda-quality text editing.
# PyMuPDF rewrites the PDF's content stream (real glyph removal, not
# the pdf-lib mask-and-draw fallback) so deletions in tinted bands
# don't leave a white-out scar. AGPL licence — fine for internal /
# server-side use, see pymupdf-backend/README.md for redistribution
# notes.
#
# Setup:
#   cd pymupdf-backend && docker compose up -d
#   curl http://localhost:8090/api/health   # should return {"status":"ok",…}
#
# When the editor mounts it pings /api/health and shows a teal
# "PyMuPDF" badge in the toolbar when reachable; on failure it falls
# back transparently to local mask-and-draw so the editor never breaks.
#
# Local:    VITE_PYMUPDF_URL=http://localhost:8090
# Deployed: VITE_PYMUPDF_URL=https://pymupdf.your-domain.com
VITE_PYMUPDF_URL=
